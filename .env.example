APP_NAME="KAE"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (Laravel) ───────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=kae
DB_USERNAME=kae
DB_PASSWORD=

# ─── Session / Cache / Queue ──────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# ─── Redis (shared by Laravel queue + Go worker) ──────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# ─── Horizon ─────────────────────────────────────────────────────────────────
# Laravel's internal queues use the default Horizon supervisor.
# DO NOT use queue name "kae_ingestion" for Laravel jobs —
# that name is reserved for the Go worker's plain-JSON protocol.

# ─── Reverb WebSockets ────────────────────────────────────────────────────────
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@kae.local"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Qdrant (shared by Laravel sync + Go worker) ─────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_GRPC_ADDR=localhost:6334
QDRANT_API_KEY=

# ─── LLM Providers (Go worker — Prism reads these in Phase 3) ────────────────
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_URL=http://localhost:11434

# ─── Embeddings (Go worker + kae-forensics) ──────────────────────────────────
EMBEDDINGS_URL=https://openrouter.ai/api/v1
EMBEDDINGS_KEY="${OPENROUTER_API_KEY}"
EMBEDDINGS_MODEL=openai/text-embedding-3-small

# ─── External Data Sources (Go worker) ───────────────────────────────────────
CORE_API_KEY=

# ─── KAE Go Worker Dispatch (plain-JSON Redis protocol) ──────────────────────
# Laravel pushes plain JSON onto kae:run_jobs (NOT through Horizon).
# Go reads via BLPOP. Go pushes status events onto kae:run_events.
KAE_RUN_JOBS_KEY=kae:run_jobs
KAE_RUN_EVENTS_KEY=kae:run_events
KAE_WORKER_BIN=/home/mark/kae/kae
KAE_WORKER_TIMEOUT=3600

VITE_APP_NAME="${APP_NAME}"
